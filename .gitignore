cat > .gitignore <<'EOF'
# Environment files — never commit
.env
.env.*
!.env.example

# Node
node_modules/
.next/
out/
dist/
build/
*.log
npm-debug.log*
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.uv-cache/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Misc
.turbo/
.vercel/
EOF